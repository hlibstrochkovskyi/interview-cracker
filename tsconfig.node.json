{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["src/shared/*"],
      "@orchestrator/*": ["src/orchestrator/*"]
    }
  },
  "include": [
    "src/main/**/*",
    "src/preload/**/*",
    "src/orchestrator/**/*",
    "src/shared/**/*",
    "scripts/**/*",
    "test/**/*",
    "electron.vite.config.ts",
    "vitest.config.ts"
  ]
}
